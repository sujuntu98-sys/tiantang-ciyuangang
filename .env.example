# === 天堂次元港 环境变量 ===

# 数据库连接 (Neon PostgreSQL)
# 本地开发也指向同一个 Neon 数据库，数据无缝共享
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# NextAuth 密钥（生产环境务必换成随机字符串）
AUTH_SECRET="your-random-secret-here"

# Vercel Blob 读写令牌（可选，不设置则使用本地文件存储）
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxx"
